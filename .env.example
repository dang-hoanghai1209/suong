# ─── Tella v1 ─── Copy to .env and fill in your own keys.

# ────────────────────────────────────────────────────────────
# Gemini (planner + ingest)
# ────────────────────────────────────────────────────────────
# Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional model overrides. Defaults inside tella/planner/story_planner.py:
#   short mode  → gemini-flash-lite-latest
#   detailed    → gemini-flash-latest
#   translation → gemini-flash-lite-latest
GEMINI_MODEL=
GEMINI_MODEL_LONG=
GEMINI_MODEL_TRANSLATE=

# ────────────────────────────────────────────────────────────
# Cloudflare Workers AI (AI image mode — FLUX)
# ────────────────────────────────────────────────────────────
# Multi-account rotation: semicolon-separated `account_id:api_token` pairs
# Each free CF account gets 10k Neurons/day. flux-schnell ~5 N/image → 2000+
# images/day per account. With 5 accounts you can render 10k+ scenes/day free.
# Get at https://dash.cloudflare.com/ → Workers AI → Use REST API
CF_ACCOUNTS=

# Single-account fallback (used when CF_ACCOUNTS is empty)
CF_ACCOUNT_ID=
CF_AI_TOKEN=

# ────────────────────────────────────────────────────────────
# Pexels (stock photo + stock video mode)
# ────────────────────────────────────────────────────────────
# Free tier: 200 req/hour, 20k req/month. SAME key for both endpoints.
# Get at https://www.pexels.com/api/new/
PEXELS_API_KEY=

# Optional rotation: comma-separated keys for higher throughput
PEXELS_API_KEYS=

# ────────────────────────────────────────────────────────────
# Google Cloud TTS (narration)
# ────────────────────────────────────────────────────────────
# Either path to service-account JSON OR raw API key.
# Prefer service-account JSON for higher quota.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_TTS_API_KEY=

# Optional: override default voice picks per language. Format JSON.
# Example: GOOGLE_TTS_VOICE_OVERRIDES={"en":"en-US-Chirp3-HD-Charon","vi":"vi-VN-Chirp3-HD-Achernar"}
GOOGLE_TTS_VOICE_OVERRIDES=

# ────────────────────────────────────────────────────────────
# Edge TTS fallback (no key required)
# ────────────────────────────────────────────────────────────
# Used when Google TTS fails. Set to "1" to disable entirely.
EDGE_TTS_DISABLED=

# ────────────────────────────────────────────────────────────
# Render output
# ────────────────────────────────────────────────────────────
# Where to drop completed jobs. Created on first run if absent.
TELLA_OUTPUT_DIR=./out

# Demo mode: render WITHOUT channel branding (no brand row, no tagline,
# no outro). CLI flag --channel="" also triggers this.
TELLA_DEMO_MODE=

# ────────────────────────────────────────────────────────────
# Channel branding (optional — a small name shown on every scene)
# ────────────────────────────────────────────────────────────
# The interactive wizard asks for this, so you usually don't set it here.
# Set it for headless/automation runs. Blank CHANNEL_NAME (or DEMO_MODE=1)
# = no brand row.
CHANNEL_NAME=
CHANNEL_HANDLE=
DEMO_MODE=

# ────────────────────────────────────────────────────────────
# Debug / dev
# ────────────────────────────────────────────────────────────
# Python: force UTF-8 in stdout (Windows quirk for Vietnamese diacritics)
PYTHONIOENCODING=utf-8
PYTHONUTF8=1
